# Multi-Stage TruffleHog Pipeline Example
# This demonstrates the DevSecOps approach with separate dev/prod scanning
# File: .github/workflows/secrets-scan-multistage.yml.example

name: Multi-Stage Security Scan

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main ]

env:
  TRUFFLEHOG_VERSION: "3.63.2-debian"

jobs:
  # Stage 1: Development Files Scan (Relaxed Rules)
  scan-development:
    name: 🔍 Scan Development Files
    runs-on: ubuntu-latest
    continue-on-error: true  # Don't fail pipeline on dev findings
    
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Create Development Paths List
        run: |
          cat > dev-paths.txt << EOF
          edc-demo.sh
          docker-compose.yml
          MANUAL_TESTING_GUIDE.md
          dataspaceconnector-configuration.properties
          samples/
          docs/development/
          **/test/**
          **/*test*.properties
          **/*demo*
          EOF

      - name: Scan Development Files (Relaxed)
        uses: trufflesecurity/trufflehog@main
        with:
          path: ./
          base: ${{ github.event.repository.default_branch }}
          extra_args: >-
            --include-paths=dev-paths.txt
            --exclude-detectors=JDBC
            --filter-entropy=4
            --results=verified
            --max-depth=3
            --debug

      - name: Upload Development Scan Results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: trufflehog-dev-results
          path: |
            **/trufflehog-*.json
          retention-days: 7

  # Stage 2: Production Code Scan (Strict Rules)
  scan-production:
    name: 🔒 Scan Production Code
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Create Production Exclusions List
        run: |
          cat > prod-exclusions.txt << EOF
          # Development and test files
          edc-demo.sh
          docker-compose.yml
          MANUAL_TESTING_GUIDE.md
          dataspaceconnector-configuration.properties
          dev-env.sh
          generate-dev-config.sh
          samples/
          docs/development/
          **/test/**
          **/*test*
          **/*demo*
          **/*example*
          
          # Build artifacts
          build/
          **/target/**
          **/.gradle/**
          **/node_modules/**
          **/*.jar
          **/*.war
          **/allure-results/**
          
          # Git and IDE
          .git/
          .vscode/
          .idea/
          EOF

      - name: Scan Production Code (Strict)
        uses: trufflesecurity/trufflehog@main
        with:
          path: ./
          base: ${{ github.event.repository.default_branch }}
          extra_args: >-
            --exclude-paths=prod-exclusions.txt
            --filter-entropy=3
            --results=verified,unknown
            --fail-on-unverified
            --debug

      - name: Upload Production Scan Results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: trufflehog-prod-results
          path: |
            **/trufflehog-*.json
          retention-days: 30

  # Stage 3: Historical Git Scan (Comprehensive)
  scan-git-history:
    name: 📚 Scan Git History
    runs-on: ubuntu-latest
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    
    steps:
      - name: Checkout Full History
        uses: actions/checkout@v4
        with:
          fetch-depth: 0  # Full history for comprehensive scan

      - name: Scan Git Objects
        uses: trufflesecurity/trufflehog@main
        with:
          path: ./
          extra_args: >-
            --exclude-detectors=JDBC
            --filter-entropy=4
            --results=verified
            --since-commit=HEAD~100
            --max-depth=5
            --debug

      - name: Upload Git History Results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: trufflehog-history-results
          path: |
            **/trufflehog-*.json
          retention-days: 90

  # Stage 4: Results Aggregation and Reporting
  aggregate-results:
    name: 📊 Aggregate Results
    runs-on: ubuntu-latest
    needs: [scan-development, scan-production, scan-git-history]
    if: always()
    
    steps:
      - name: Download All Results
        uses: actions/download-artifact@v4
        with:
          path: ./scan-results

      - name: Generate Security Report
        run: |
          echo "# 🔐 Security Scan Summary" > security-report.md
          echo "" >> security-report.md
          echo "**Scan Date:** $(date)" >> security-report.md
          echo "**Branch:** ${{ github.ref_name }}" >> security-report.md
          echo "**Commit:** ${{ github.sha }}" >> security-report.md
          echo "" >> security-report.md
          
          echo "## 📋 Scan Results" >> security-report.md
          echo "" >> security-report.md
          
          # Process development results
          if [ -d "./scan-results/trufflehog-dev-results" ]; then
            echo "### 🔍 Development Files" >> security-report.md
            echo "- Status: ✅ Completed (relaxed rules)" >> security-report.md
            echo "- Files: Development and test files" >> security-report.md
            echo "- Rules: JDBC detector excluded" >> security-report.md
            echo "" >> security-report.md
          fi
          
          # Process production results
          if [ -d "./scan-results/trufflehog-prod-results" ]; then
            echo "### 🔒 Production Code" >> security-report.md
            echo "- Status: ✅ Completed (strict rules)" >> security-report.md
            echo "- Files: Production source code" >> security-report.md
            echo "- Rules: All detectors enabled" >> security-report.md
            echo "" >> security-report.md
          fi
          
          # Process history results
          if [ -d "./scan-results/trufflehog-history-results" ]; then
            echo "### 📚 Git History" >> security-report.md
            echo "- Status: ✅ Completed (last 100 commits)" >> security-report.md
            echo "- Scope: Git objects and history" >> security-report.md
            echo "- Rules: JDBC detector excluded" >> security-report.md
            echo "" >> security-report.md
          fi
          
          echo "## 🎯 Recommendations" >> security-report.md
          echo "" >> security-report.md
          echo "- ✅ Development credentials properly isolated" >> security-report.md
          echo "- ✅ Production code scanned with strict rules" >> security-report.md
          echo "- ✅ Git history checked for leaked secrets" >> security-report.md
          echo "- 🔄 Consider implementing secret rotation policies" >> security-report.md
          echo "- 📚 Review security training for development team" >> security-report.md

      - name: Upload Security Report
        uses: actions/upload-artifact@v4
        with:
          name: security-scan-report
          path: security-report.md
          retention-days: 90

      - name: Comment on PR
        if: github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const report = fs.readFileSync('security-report.md', 'utf8');
            
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: `## 🔐 Security Scan Results\n\n${report}\n\n*This scan uses multi-stage approach with different rules for development and production code.*`
            });

  # Stage 5: Security Metrics Collection (Optional)
  collect-metrics:
    name: 📈 Collect Security Metrics
    runs-on: ubuntu-latest
    needs: [aggregate-results]
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    
    steps:
      - name: Calculate Security Metrics
        run: |
          echo "Collecting security scan metrics..."
          echo "- Scan frequency: Every push/PR"
          echo "- Coverage: Development + Production + Git History"
          echo "- False positive rate: Minimized with multi-stage approach"
          echo "- Scan duration: ~5-10 minutes total"
          
          # Here you could send metrics to your monitoring system
          # curl -X POST "https://your-metrics-endpoint.com/api/security-metrics" \
          #   -H "Content-Type: application/json" \
          #   -d '{"scan_date":"'$(date -I)'","status":"success","duration":"'$duration'"}'
